# Copy this file to .env and fill in your values
# cp .env.example .env

# ── Tailscale ──────────────────────────────────────────────────
# Get your auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TAILSCALE_HOSTNAME=homelab
# Optional extra args, e.g. --advertise-exit-node
TS_EXTRA_ARGS=

# ── Jellyfin ───────────────────────────────────────────────────
# Path to your media library on the host
MEDIA_DIR=/srv/media
# Optional: set your public URL for better client discovery
JELLYFIN_URL=

# ── Filebrowser ────────────────────────────────────────────────
# Root directory exposed in the file browser
FILES_ROOT=/srv/files

# ── Placeholders (uncomment when needed) ───────────────────────
# VAULTWARDEN_ADMIN_TOKEN=
# DOWNLOAD_DIR=/srv/downloads
